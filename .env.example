# ----- PostgreSQL -----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dashboard_db
DB_USER=dashboard_user
DB_PASSWORD=your_password_here

# ----- Flask -----
SECRET_KEY=your_secret_key_here
SESSION_TTL=28800
PORT=8080

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Auth -----
ENABLE_REGISTRATION=True

# ----- Paths -----
DATA_FOLDER=./data
SYNC_QUEUE_FILE=./sync_exports/pending_sync.json
LOG_FOLDER=./logs

# ----- Mail -----
EMAIL_FROM=your_email@yandex.ru
EMAIL_PASSWORD=your_app_password
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465

# ----- Sync -----
ALWAYS_NOTIFY=email@example.com
